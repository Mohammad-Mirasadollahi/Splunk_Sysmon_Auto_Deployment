<Sysmon schemaversion="4.90">
  <!-- DEFAULT Sysmon configuration shipped with TA-Sysmon-Config. -->
  <!-- Minimal: log process activity only. -->
  <!-- Do NOT edit this file. To customize, create your own config at         -->
  <!--   TA-Sysmon-Config/local/config.xml                                     -->
  <!-- which OVERRIDES this default (standard Splunk default/local behavior).  -->
  <EventFiltering>
    <!-- Event ID 1: log every process creation (empty "exclude" excludes nothing). -->
    <RuleGroup name="ProcessCreate" groupRelation="or">
      <ProcessCreate onmatch="exclude" />
    </RuleGroup>

    <!-- Event ID 5: log every process termination. -->
    <RuleGroup name="ProcessTerminate" groupRelation="or">
      <ProcessTerminate onmatch="exclude" />
    </RuleGroup>
  </EventFiltering>
</Sysmon>
