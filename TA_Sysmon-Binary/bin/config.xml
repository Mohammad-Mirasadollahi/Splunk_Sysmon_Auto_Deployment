<Sysmon schemaversion="4.90">
  <EventFiltering>
    <!-- Event ID 1: Log ALL Process Creations -->
    <RuleGroup name="Process_Creation" groupRelation="or">
      <!-- "exclude" with no rules inside means "do not exclude anything" -> log everything -->
      <ProcessCreate onmatch="exclude" />
    </RuleGroup>
  </EventFiltering>
</Sysmon>
